# 后端本地配置示例（占位符，勿填入真实密钥后提交仓库）。
#
# 推荐：复制本文件为 web/.env 或项目根目录 .env（二者均已 .gitignore），
# 填入密钥后执行: pip install -r requirements-web.txt && python web/app.py
# web/.env 会覆盖根目录 .env 中的同名变量。
#
# 亦可仅在启动后端的同一 PowerShell 里设置：
#   $env:DASHSCOPE_API_KEY = "sk-..."
#   python web/app.py

# 打版图提供方: auto | dashscope | minimax | none
# auto：若配置了 DASHSCOPE 则优先通义万相，否则 MiniMax
# TECH_SHEET_PROVIDER=auto

# 阿里云百炼 / 通义万相 图生图（与上面二选一或 auto 优先）
# DASHSCOPE_API_KEY=
# 与 DASHSCOPE_API_KEY 二选一，内容均为百炼控制台 API-Key
# QWEN_API_KEY=

# 北京: https://dashscope.aliyuncs.com  国际: https://dashscope-intl.aliyuncs.com（需与 Key 地域一致）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com

# 万相图生图模型，默认 wan2.5-i2i-preview
# WANX_I2I_MODEL=wan2.5-i2i-preview

# 通义万相：轮询间隔与超时（秒）
# DASHSCOPE_POLL_INTERVAL=10
# DASHSCOPE_POLL_TIMEOUT=600

# 参考图压成 JPEG 再传，避免 400（请求体过大）
# DASHSCOPE_IMAGE_MAX_SIDE=2048
# DASHSCOPE_MIN_EDGE=384
# DASHSCOPE_IMAGE_MAX_BYTES=4194304
# DASHSCOPE_PROMPT_EXTEND=false

# 通义：覆盖英文 prompt（与 MINIMAX_TECH_PROMPT 二选一时本脚本优先 QWEN_TECH_PROMPT）
# QWEN_TECH_PROMPT=

# MiniMax 图生图（打版图）
MINIMAX_API_KEY=

# 可选；默认 https://api.minimaxi.com
# MINIMAX_API_BASE=https://api.minimaxi.com

# 可选；生成打版图数量上限，0 或未设置表示全部（慎用额度）
# MINIMAX_MAX_IMAGES=0

# 可选；自定义英文 prompt（≤1500 字符）
# MINIMAX_TECH_PROMPT=

# 可选；两次 MiniMax 请求间隔秒数，默认 1.5
# MINIMAX_SLEEP_SEC=1.5

# 可选；HTTP 监听端口，默认 8765（前端 Vite 代理需与之对齐）
# BACKEND_PORT=8765
